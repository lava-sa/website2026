RESEND_API_KEY=your_resend_api_key

# Resend: the domain in EMAIL_FROM must show "Verified" in the Resend dashboard.
# Add the exact TXT/MX records Resend shows (hostnames must match — e.g. send.lava-sa.co.za, not send.send...).

# Optional central email settings (used by orders, contact, and Janet routes)
EMAIL_FROM="Lava-SA Orders <noreply@lava-sa.online>"
EMAIL_ADMIN_TO="info@lava-sa.co.za"
EMAIL_REPLY_TO="info@lava-sa.co.za"

# Backward-compatible order-specific overrides (optional)
ORDER_EMAIL_FROM="Lava-SA Orders <noreply@lava-sa.online>"

# Comma-separated recipients for internal order alerts
ORDER_EMAIL_ADMIN_TO="info@lava-sa.co.za"

# Optional reply-to address for customer-facing transactional emails
ORDER_EMAIL_REPLY_TO="info@lava-sa.co.za"

# Public EFT details (optional overrides; defaults match checkout success page)
# EFT_BANK_NAME=Nedbank
# EFT_ACCOUNT_NAME=LAVA VIDE SA (PTY) LTD
# EFT_ACCOUNT_NUMBER=1123920508
# EFT_BRANCH_CODE=198765
# EFT_ACCOUNT_TYPE=Cheque / Current

# Admin dashboard — rough product “profit” ranking (no COGS field in DB)
# ESTIMATED_GROSS_MARGIN_PCT=35

# 2026 sales target = 2025 eligible revenue × (1 + this). Example: 0.10 = +10% YoY
# SALES_TARGET_YOY_GROWTH=0.1
