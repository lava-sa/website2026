RESEND_API_KEY=your_resend_api_key
CRON_SECRET=your_strong_random_cron_secret

# Canonical public URL (PayFast return/cancel URLs, email links, member auth redirects).
# Must match Supabase → Authentication → URL Configuration → Site URL.
NEXT_PUBLIC_SITE_URL=https://www.lava-sa.com

# Site-wide preview gate (set password to enable; remove or SITE_ACCESS_ENABLED=false to go live)
# SITE_ACCESS_ENABLED=true
# SITE_ACCESS_PASSWORD=your-preview-password
# SITE_ACCESS_SECRET=optional-random-string-for-cookie-signing

# Cloudflare Turnstile (spam protection on contact, reviews, mailing list)
# Create at https://dash.cloudflare.com → Turnstile → Add widget (hostname: lava-sa.com, www.lava-sa.com)
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key
# TURNSTILE_SECRET_KEY=your_turnstile_secret_key

# Resend: the domain in EMAIL_FROM must show "Verified" in the Resend dashboard.
# Use the exact subdomain Resend gives you (e.g. send.lava-sa.com under lava-sa.com DNS).

# Optional central email settings (used by orders, contact, and Janet routes)
EMAIL_FROM="Lava-SA Orders <noreply@send.lava-sa.com>"
EMAIL_ADMIN_TO="info@lava-sa.com"
EMAIL_REPLY_TO="info@lava-sa.com"

# Backward-compatible order-specific overrides (optional)
ORDER_EMAIL_FROM="Lava-SA Orders <noreply@send.lava-sa.com>"

# Comma-separated recipients for internal order alerts
ORDER_EMAIL_ADMIN_TO="info@lava-sa.com"

# Review submissions always notify anneke@lava-sa.co.za and reviews@lava-sa.com (see src/lib/reviews/email.ts).
# EMAIL_ADMIN_TO above is also included when set.

# Optional reply-to address for customer-facing transactional emails
ORDER_EMAIL_REPLY_TO="info@lava-sa.com"

# Public EFT details (optional overrides; defaults match checkout success page)
# EFT_BANK_NAME=Nedbank
# EFT_ACCOUNT_NAME=LAVA VIDE SA (PTY) LTD
# EFT_ACCOUNT_NUMBER=1123920508
# EFT_BRANCH_CODE=198765
# EFT_ACCOUNT_TYPE=Cheque / Current

# Admin dashboard — rough product “profit” ranking (no COGS field in DB)
# ESTIMATED_GROSS_MARGIN_PCT=35

# 2026 sales target = 2025 eligible revenue × (1 + this). Example: 0.10 = +10% YoY
# SALES_TARGET_YOY_GROWTH=0.1
